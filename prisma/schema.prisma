generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// User accounts
model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  passwordHash  String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  profile       CrsProfile?
  settings      Settings?
  documents     Document[]
}

// Express Entry Draws (shared, not user-scoped)
model Draw {
  id             String   @id @default(cuid())
  drawNumber     Int      @unique
  drawDate       DateTime
  drawName       String
  crsScore       Int
  itasIssued     Int
  tieBreakDate   DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// Provincial Nominee Program Draws
model PnpDraw {
  id           String   @id @default(cuid())
  province     String
  stream       String
  drawDate     DateTime
  minScore     Int?
  itasIssued   Int?
  nocCodes     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// IRCC News and Updates
model News {
  id          String   @id @default(cuid())
  title       String
  summary     String?
  url         String
  publishDate DateTime
  category    String?
  createdAt   DateTime @default(now())
}

// Document Checklist Items (user-scoped)
model Document {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  category    String
  description String?
  isCompleted Boolean  @default(false)
  dueDate     DateTime?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// User Settings (user-scoped)
model Settings {
  id                   String  @id @default(cuid())
  userId               String  @unique
  user                 User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  telegramBotToken     String?
  telegramChatId       String?
  emailAddress         String?
  crsAlertThreshold    Int     @default(500)
  enableTelegram       Boolean @default(false)
  enableEmail          Boolean @default(true)
  enableDrawAlerts     Boolean @default(true)
  enablePnpAlerts      Boolean @default(true)
  enableNewsAlerts     Boolean @default(false)
}

// CRS Profile (user-scoped)
model CrsProfile {
  id                    String  @id @default(cuid())
  userId                String  @unique
  user                  User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Core Human Capital Factors
  age                   Int     @default(25)
  educationLevel        String  @default("bachelors")
  firstLanguageTest     String  @default("ielts")
  firstLanguageScores   String  @default("{}")
  secondLanguageScores  String?
  canadianWorkYears     Int     @default(0)
  foreignWorkYears      Int     @default(0)
  // Spouse Factors
  hasSpouse             Boolean @default(false)
  spouseEducation       String?
  spouseLanguageScores  String?
  spouseCanadianWork    Int     @default(0)
  // Additional Points
  provincialNomination  Boolean @default(false)
  jobOffer              String?
  canadianEducation     String?
  frenchAbility         String?
  sibling               Boolean @default(false)
  // Program eligibility fields
  nocCode               String?
  nocTeerCategory       String?
  preferredProvinces    String?
  // Important dates for timeline tracking
  ieltsTestDate         DateTime?
  medicalExamDate       DateTime?
  policeClearanceDate   DateTime?
  ecaIssueDate          DateTime?
  irccProfileCreatedDate DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

// Processing Times Cache
model ProcessingTime {
  id            String   @id @default(cuid())
  programName   String   @unique
  processingDays Int
  lastUpdated   DateTime
  createdAt     DateTime @default(now())
}
